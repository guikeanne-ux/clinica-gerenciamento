{
  "name": "clinica-gerenciamento/backend",
  "description": "Backend base da clinica em PHP 8.3 puro",
  "type": "project",
  "require": {
    "php": "^8.3",
    "illuminate/database": "^12.0",
    "illuminate/events": "^12.0",
    "symfony/routing": "^7.0",
    "symfony/validator": "^7.0",
    "vlucas/phpdotenv": "^5.6",
    "firebase/php-jwt": "^6.10"
  },
  "require-dev": {
    "fakerphp/faker": "^1.24",
    "pestphp/pest": "^3.8",
    "phpstan/phpstan": "^2.1",
    "squizlabs/php_codesniffer": "^3.10"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "pest",
    "test:coverage": "pest --coverage",
    "test-coverage": "@test:coverage",
    "lint": "phpcs",
    "lint:fix": "phpcbf",
    "lint-fix": "@lint:fix",
    "phpstan": "phpstan analyse --memory-limit=512M"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
